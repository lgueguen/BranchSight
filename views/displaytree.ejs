function colorByRate(rate) {
    if (upperThresholdMode) {
        return 'hsl(0, 100%, '+ Math.min(90,(85 * (1 - rate)^2))+'%)';
    } else {
        return 'hsl(250, 100%, '+ Math.min(85,(85 * (1 - rate)^2)) +'%)';
    }
}
 
